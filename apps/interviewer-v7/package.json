{
  "name": "@codaco/interviewer-v7",
  "version": "0.1.0",
  "private": true,
  "description": "Network Canvas Interviewer v7 — Vite + React 19 dashboard hosting the @codaco/interview engine, with desktop (Electron) and tablet (Capacitor) targets.",
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:dist": "pnpm electron:build && electron-builder --config electron-builder.config.cjs",
    "electron:dist:mac": "pnpm electron:build && electron-builder --mac --config electron-builder.config.cjs",
    "electron:dist:win": "pnpm electron:build && electron-builder --win --config electron-builder.config.cjs",
    "electron:dist:linux": "pnpm electron:build && electron-builder --linux --config electron-builder.config.cjs",
    "capacitor:sync": "pnpm build && cap sync",
    "capacitor:add:ios": "cap add ios",
    "capacitor:add:android": "cap add android",
    "capacitor:open:ios": "cap open ios",
    "capacitor:open:android": "cap open android",
    "capacitor:run:ios": "pnpm build && cap run ios",
    "capacitor:run:android": "pnpm build && cap run android",
    "capacitor:dev:android": "pnpm build && CAP_DEV_SERVER_URL=http://10.0.2.2:5180 cap sync android && concurrently -k -s first -n vite,cap \"vite\" \"CAP_DEV_SERVER_URL=http://10.0.2.2:5180 cap run android ${CAP_ANDROID_TARGET:+--target $CAP_ANDROID_TARGET}\"",
    "capacitor:dev:ios": "pnpm build && CAP_DEV_SERVER_URL=http://localhost:5180 cap sync ios && concurrently -k -s first -n vite,cap \"vite\" \"CAP_DEV_SERVER_URL=http://localhost:5180 cap run ios\"",
    "assets:generate-inputs": "node scripts/generate-icon-assets.mjs",
    "assets:generate-android": "pnpm assets:generate-inputs && capacitor-assets generate --android --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3",
    "assets:generate-ios": "pnpm assets:generate-inputs && capacitor-assets generate --ios --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3 && node scripts/add-ios-app-icon.mjs",
    "assets:generate-all": "pnpm assets:generate-inputs && capacitor-assets generate --android --ios --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3 && node scripts/add-ios-app-icon.mjs",
    "capacitor:sync:before": "pnpm assets:generate-all",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^9.0.0",
    "@base-ui/react": "catalog:",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.1",
    "@codaco/art": "workspace:*",
    "@codaco/fresco-ui": "workspace:*",
    "@codaco/interview": "workspace:*",
    "@codaco/network-exporters": "workspace:*",
    "@codaco/protocol-validation": "workspace:*",
    "@codaco/shared-consts": "workspace:*",
    "@codaco/tailwind-config": "workspace:*",
    "@codaco/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "dexie": "^4.4.2",
    "effect": "catalog:",
    "jszip": "^3.10.1",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "uuid": "catalog:",
    "wouter": "^3.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@electron/rebuild": "^4.0.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "concurrently": "^9.2.1",
    "electron": "catalog:",
    "electron-builder": "^26.8.1",
    "electron-vite": "^6.0.0-beta.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.2",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "xcode": "^3.0.1"
  }
}
