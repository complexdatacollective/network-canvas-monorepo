<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-user, offline-first research-data-collection app: protocols, sessions
  and authenticator metadata MUST stay on the device. Excluding everything from
  both cloud and device-to-device transfers prevents Android Backup from copying
  IndexedDB / Preferences out of the app sandbox.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
