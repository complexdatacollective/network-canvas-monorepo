{
  "name": "Social Connection & Isolation",
  "description": "An egocentric personal-network protocol that distinguishes OBJECTIVE social isolation (the structure and composition of a respondent's network) from SUBJECTIVE loneliness (validated self-report scales). Ageing/loneliness is the lead exemplar. The signature technique is a concentric OrdinalBin closeness map combined with standardised loneliness and social-network scales (UCLA-3, De Jong Gierveld 6-item, Lubben LSNS-6) embedded in an EgoForm, so network structure and subjective loneliness sit in one dataset.",
  "schemaVersion": 8,
  "lastModified": "2026-06-15T00:00:00.000Z",
  "codebook": {
    "ego": {
      "variables": {
        "living_situation": {
          "name": "living_situation",
          "type": "categorical",
          "component": "ToggleButtonGroup",
          "options": [
            { "label": "I live alone", "value": "alone" },
            {
              "label": "I live with a spouse or partner only",
              "value": "partner"
            },
            {
              "label": "I live with family (other than a partner)",
              "value": "family"
            },
            {
              "label": "I live with friends or housemates",
              "value": "housemates"
            },
            {
              "label": "I live in a care or residential setting",
              "value": "residential"
            },
            { "label": "Other living arrangement", "value": "other" }
          ],
          "validation": { "required": true }
        },
        "self_rated_health": {
