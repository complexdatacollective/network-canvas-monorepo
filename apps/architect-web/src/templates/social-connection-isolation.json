  "stages": [
    {
      "id": "ego-form-demographics",
      "type": "EgoForm",
      "label": "About You",
      "introductionPanel": {
        "title": "About you and your household",
        "text": "To begin, we would like to ask a few questions about **you** and your current living situation. Your answers help us understand the context of your social connections."
      },
      "form": {
        "title": "Your background",
        "fields": [
          {
            "variable": "living_situation",
            "prompt": "Which of the following best describes your current living situation?"
          },
          {
            "variable": "self_rated_health",
            "prompt": "In general, how would you rate your health?"
          }
        ]
      }
    },
    {
      "id": "name-generator-confidants",
      "type": "NameGenerator",
      "label": "People You Discuss Important Matters With",
      "panels": [
        {
          "id": "name-generator-confidants-existing",
          "title": "Already mentioned",
          "dataSource": "existing"
        }
      ],
      "interviewScript": "Use the standard General Social Survey 'important matters' confidant generator. Allow the respondent to name as many or as few people as they wish; do not prompt for a target number.",
      "subject": {
        "entity": "node",
        "type": "person"
      },
      "form": {
        "title": "Add a person",
        "fields": [
          {
            "variable": "alter_name",
            "prompt": "What is this person's first name or initials?"
          }
        ]
      },
      "prompts": [
        {
          "id": "gss-important-matters",
          "text": "Looking back over the last six months, who are the people with whom you discussed matters important to you?"
        }
      ]
    },
    {
      "id": "ordinal-bin-closeness",
      "type": "OrdinalBin",
      "label": "How Close Are They?",
      "subject": {
        "entity": "node",
        "type": "person"
      },
      "prompts": [
        {
          "id": "closeness-bands",
          "text": "Place each person into the band that best describes how close you feel to them, from **not close** in the outer band to **very close** in the centre.",
          "variable": "closeness"
        }
      ]
    },
    {
      "id": "alter-form-attributes",
      "type": "AlterForm",
      "label": "About Each Person",
      "subject": {
        "entity": "node",
        "type": "person"
      },
      "introductionPanel": {
        "title": "A little more about each person",
        "text": "For each person you named, we would like to ask about your **contact** with them and the kinds of **support** they provide."
      },
      "form": {
        "title": "About this person",
        "fields": [
          {
            "variable": "relationship",
            "prompt": "What is this person's relationship to you?"
          },
          {
            "variable": "age_band",
            "prompt": "Roughly how old is this person?"
          },
          {
            "variable": "contact_frequency",
            "prompt": "How often are you in contact with this person?"
          },
          {
            "variable": "contact_mode",
            "prompt": "How do you usually keep in contact with this person? (Select all that apply.)"
          },
          {
            "variable": "lives_with",
            "prompt": "Does this person live with you?"
          },
          {
            "variable": "support_emotional",
            "prompt": "Could you turn to this person for **emotional** support, such as talking things over when you feel down?"
          },
          {
            "variable": "support_practical",
            "prompt": "Could you turn to this person for **practical** support, such as help with tasks, transport, or money?"
          }
        ]
      }
    },
    {
      "id": "sociogram-ties",
      "type": "Sociogram",
      "label": "Connections Between People",
      "interviewScript": "Ask the respondent to draw a tie between any two people who know one another. A network where alters cluster together suggests a connected core; isolated nodes suggest fragmentation.",
      "subject": {
        "entity": "node",
        "type": "person"
      },
      "background": {
        "concentricCircles": 4,
        "skewedTowardCenter": true
      },
      "prompts": [
        {
          "id": "alter-alter-ties",
          "text": "Draw a line between any two people who **know one another**. This helps us see which of your contacts are connected.",
          "layout": {
            "layoutVariable": "layout"
          },
          "edges": {
            "create": "knows",
            "display": ["knows"]
          }
        }
      ]
    },
    {
      "id": "ego-form-scales",
      "type": "EgoForm",
      "label": "Your Feelings About Connection",
      "introductionPanel": {
        "title": "Your feelings about social connection",
        "text": "Finally, we would like to understand how you **feel** about your social connections. There are no right or wrong answers. These questions use three well-established sets of items, so the wording is fixed."
      },
      "form": {
        "title": "How you feel",
        "fields": [
          {
            "variable": "ucla_1",
            "prompt": "How often do you feel that you lack companionship?"
          },
          {
            "variable": "ucla_2",
            "prompt": "How often do you feel left out?"
          },
          {
            "variable": "ucla_3",
            "prompt": "How often do you feel isolated from others?"
          },
          {
            "variable": "djg_1",
            "prompt": "I experience a general sense of emptiness."
          },
          {
            "variable": "djg_2",
            "prompt": "I miss having people around me."
          },
          {
            "variable": "djg_3",
            "prompt": "I often feel rejected."
          },
          {
            "variable": "djg_4",
            "prompt": "There are plenty of people I can rely on when I have problems."
          },
          {
            "variable": "djg_5",
            "prompt": "There are many people I can trust completely."
          },
          {
            "variable": "djg_6",
            "prompt": "There are enough people I feel close to."
          },
          {
            "variable": "lsns_1",
            "prompt": "Considering people you are related to: how many relatives do you see or hear from at least once a month?"
          },
          {
            "variable": "lsns_2",
            "prompt": "How many relatives do you feel at ease with that you can talk about private matters?"
          },
          {
            "variable": "lsns_3",
            "prompt": "How many relatives do you feel close to such that you could call on them for help?"
          },
          {
            "variable": "lsns_4",
            "prompt": "Considering all of your friends: how many of your friends do you see or hear from at least once a month?"
          },
          {
            "variable": "lsns_5",
            "prompt": "How many friends do you feel at ease with that you can talk about private matters?"
          },
          {
            "variable": "lsns_6",
            "prompt": "How many friends do you feel close to such that you could call on them for help?"
          }
        ]
      }
    }
  ]
}
