{
  "name": "Care & Support Networks",
  "description": "An example of a study that looks at who supports a participant through a period of care, and the kinds of support they provide — emotional, practical, informational, and financial — across both informal and professional sources. Configured here for the perinatal period (pregnancy and new parenthood).",
  "schemaVersion": 8,
  "lastModified": "2026-06-15T00:00:00.000Z",
  "codebook": {
    "ego": {
      "variables": {
        "care_stage": {
          "name": "care_stage",
          "type": "categorical",
          "component": "ToggleButtonGroup",
          "options": [
            { "label": "Pregnant", "value": "pregnant" },
            { "label": "Postpartum (baby already born)", "value": "postpartum" }
          ],
          "validation": { "required": true }
        },
        "weeks_since_birth": {
          "name": "weeks_since_birth",
          "type": "number",
          "component": "Number",
          "validation": { "minValue": 0, "maxValue": 104 }
        },
        "living_situation": {
          "name": "living_situation",
          "type": "categorical",
          "component": "ToggleButtonGroup",
          "options": [
            {
              "label": "Living with a partner / spouse",
              "value": "with_partner"
            },
            {
              "label": "Living with other family or relatives",
              "value": "with_family"
            },
            {
              "label": "Living with friends or housemates",
              "value": "with_others"
            },
            { "label": "Living alone", "value": "alone" }
          ]
        },
        "epds_1": {
          "name": "epds_1",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "As much as I always could", "value": 0 },
            { "label": "Not quite so much now", "value": 1 },
            { "label": "Definitely not so much now", "value": 2 },
            { "label": "Not at all", "value": 3 }
          ]
        },
        "epds_2": {
          "name": "epds_2",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "As much as I ever did", "value": 0 },
            { "label": "Rather less than I used to", "value": 1 },
            { "label": "Definitely less than I used to", "value": 2 },
            { "label": "Hardly at all", "value": 3 }
          ]
        },
        "epds_3": {
          "name": "epds_3",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, most of the time", "value": 3 },
            { "label": "Yes, some of the time", "value": 2 },
            { "label": "Not very often", "value": 1 },
            { "label": "No, never", "value": 0 }
          ]
        },
        "epds_4": {
          "name": "epds_4",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "No, not at all", "value": 0 },
            { "label": "Hardly ever", "value": 1 },
            { "label": "Yes, sometimes", "value": 2 },
            { "label": "Yes, very often", "value": 3 }
          ]
        },
        "epds_5": {
          "name": "epds_5",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, quite a lot", "value": 3 },
            { "label": "Yes, sometimes", "value": 2 },
            { "label": "No, not much", "value": 1 },
            { "label": "No, not at all", "value": 0 }
          ]
        },
        "epds_6": {
          "name": "epds_6",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            {
              "label": "Yes, most of the time I haven't been able to cope at all",
              "value": 3
            },
            {
              "label": "Yes, sometimes I haven't been coping as well as usual",
              "value": 2
            },
            {
              "label": "No, most of the time I have coped quite well",
              "value": 1
            },
            { "label": "No, I have been coping as well as ever", "value": 0 }
          ]
        },
        "epds_7": {
          "name": "epds_7",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, most of the time", "value": 3 },
            { "label": "Yes, sometimes", "value": 2 },
            { "label": "Not very often", "value": 1 },
            { "label": "No, not at all", "value": 0 }
          ]
        },
        "epds_8": {
          "name": "epds_8",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, most of the time", "value": 3 },
            { "label": "Yes, quite often", "value": 2 },
            { "label": "Not very often", "value": 1 },
            { "label": "No, not at all", "value": 0 }
          ]
        },
        "epds_9": {
          "name": "epds_9",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, most of the time", "value": 3 },
            { "label": "Yes, quite often", "value": 2 },
            { "label": "Only occasionally", "value": 1 },
            { "label": "No, never", "value": 0 }
          ]
        },
        "epds_10": {
          "name": "epds_10",
          "type": "ordinal",
          "component": "LikertScale",
          "options": [
            { "label": "Yes, quite often", "value": 3 },
            { "label": "Sometimes", "value": 2 },
            { "label": "Hardly ever", "value": 1 },
            { "label": "Never", "value": 0 }
          ]
        }
      }
    },
    "node": {
      "supporter": {
        "name": "Supporter",
        "color": "node-color-seq-1",
        "icon": "add-a-person",
        "shape": { "default": "circle" },
        "variables": {
          "supporter_name": {
            "name": "supporter_name",
            "type": "text",
            "component": "Text",
            "validation": { "required": true, "unique": true }
          },
          "relationship": {
            "name": "relationship",
            "type": "categorical",
            "component": "ToggleButtonGroup",
            "options": [
              { "label": "Partner or spouse", "value": "partner" },
              { "label": "Parent or parent-in-law", "value": "parent" },
              { "label": "Other family member", "value": "family" },
              { "label": "Friend", "value": "friend" },
              { "label": "Another parent / peer", "value": "peer_parent" },
              { "label": "Neighbour", "value": "neighbour" },
              { "label": "Healthcare or service provider", "value": "provider" }
            ]
          },
          "formal_informal": {
            "name": "formal_informal",
            "type": "categorical",
            "component": "ToggleButtonGroup",
            "options": [
              {
                "label": "Informal (family, friends, peers)",
                "value": "informal"
              },
              {
                "label": "Formal or professional (clinician, doula, home-visiting nurse, community health worker)",
                "value": "formal"
              }
            ]
          },
          "support_functions": {
            "name": "support_functions",
            "type": "categorical",
            "component": "CheckboxGroup",
            "options": [
              { "label": "Emotional support", "value": "emotional" },
              { "label": "Information or advice", "value": "informational" },
              { "label": "Practical help or childcare", "value": "practical" },
              { "label": "Financial help", "value": "financial" }
            ],
            "validation": { "minSelected": 1 }
          },
          "proximity": {
            "name": "proximity",
            "type": "categorical",
            "component": "ToggleButtonGroup",
            "options": [
              { "label": "Same household", "value": "same_household" },
              { "label": "Nearby", "value": "nearby" },
              { "label": "Far away", "value": "far_away" },
              { "label": "Online only", "value": "online_only" }
            ]
          },
          "contact_frequency": {
            "name": "contact_frequency",
            "type": "ordinal",
            "component": "RadioGroup",
            "options": [
              { "label": "Every day", "value": 5 },
              { "label": "A few times a week", "value": 4 },
              { "label": "About once a week", "value": 3 },
              { "label": "A few times a month", "value": 2 },
              { "label": "Less than once a month", "value": 1 }
            ]
          },
          "reliance": {
            "name": "reliance",
            "type": "ordinal",
            "component": "LikertScale",
            "options": [
              { "label": "Not at all", "value": 1 },
              { "label": "A little", "value": 2 },
              { "label": "A moderate amount", "value": 3 },
              { "label": "A lot", "value": 4 },
              { "label": "Completely", "value": 5 }
            ]
          },
          "layout": {
            "name": "layout",
            "type": "layout"
          }
        }
      }
    }
  },
  "stages": [
    {
      "id": "information-researcher-notes",
      "type": "Information",
      "label": "Template notes (delete before fielding)",
      "title": "Template notes",
      "items": [
        {
          "id": "researcher-notes",
          "type": "text",
          "content": "## For researchers\n\n_Delete this screen before you field the study._\n\n**Clinical safety:** the EPDS is a screening tool, not a diagnostic instrument. Item 10 screens for thoughts of self-harm, so before fielding put a safety protocol in place — interviewer training, an escalation pathway, and local crisis-line and referral details — for any participant who endorses item 10 or otherwise shows distress.\n\nThe instruments this template draws on:\n\n- [Cox JL, Holden JM, Sagovsky R (1987). Detection of postnatal depression: the 10-item Edinburgh Postnatal Depression Scale (EPDS). *Br J Psychiatry* 150:782–786.](https://pubmed.ncbi.nlm.nih.gov/3651732/)\n- [Sherbourne CD, Stewart AL (1991). The MOS Social Support Survey. *Soc Sci Med* 32(6):705–714.](https://www.rand.org/pubs/reprints/RP218.html)"
        }
      ]
    },
    {
      "id": "information-intro",
      "type": "Information",
      "label": "Welcome",
      "title": "About this study",
      "items": [
        {
          "id": "intro-welcome",
          "type": "text",
          "content": "## Welcome\n\nThank you for taking part. In this interview we will talk about the **people who support you** during this period, and the kinds of help they provide. There are no right or wrong answers — we are interested in your own experience."
        }
      ]
    },
    {
      "id": "ego-care-context",
      "type": "EgoForm",
      "label": "About you and your care episode",
      "interviewScript": "Clinical safety: EPDS item 10 screens for thoughts of self-harm. Before fielding this protocol, put a safety protocol in place — interviewer training, an escalation pathway, and local crisis-line / referral details — for any participant who endorses item 10 or otherwise shows distress. The software records responses but does not act on them.",
      "introductionPanel": {
        "title": "About you right now",
        "text": "First, a few questions about where you are in your care journey, and how you have been feeling.\n\nThe questions about your mood come from the **Edinburgh Postnatal Depression Scale (EPDS)**. There are no right or wrong answers. Please answer based on how you have felt in the **past 7 days**, not just today."
      },
      "form": {
        "fields": [
          {
            "variable": "care_stage",
            "prompt": "Where are you in your care journey at the moment?"
          },
          {
            "variable": "weeks_since_birth",
            "prompt": "If your baby has already been born, how many weeks ago was that?",
            "hint": "Leave blank if you are still pregnant."
          },
          {
            "variable": "living_situation",
            "prompt": "Which best describes who you live with right now?"
          },
          {
            "variable": "epds_1",
            "prompt": "In the past 7 days: I have been able to laugh and see the funny side of things."
          },
          {
            "variable": "epds_2",
            "prompt": "In the past 7 days: I have looked forward with enjoyment to things."
          },
          {
            "variable": "epds_3",
            "prompt": "In the past 7 days: I have blamed myself unnecessarily when things went wrong."
          },
          {
            "variable": "epds_4",
            "prompt": "In the past 7 days: I have been anxious or worried for no good reason."
          },
          {
            "variable": "epds_5",
            "prompt": "In the past 7 days: I have felt scared or panicky for no very good reason."
          },
          {
            "variable": "epds_6",
            "prompt": "In the past 7 days: Things have been getting on top of me."
          },
          {
            "variable": "epds_7",
            "prompt": "In the past 7 days: I have been so unhappy that I have had difficulty sleeping."
          },
          {
            "variable": "epds_8",
            "prompt": "In the past 7 days: I have felt sad or miserable."
          },
          {
            "variable": "epds_9",
            "prompt": "In the past 7 days: I have been so unhappy that I have been crying."
          },
          {
            "variable": "epds_10",
            "prompt": "In the past 7 days: The thought of harming myself has occurred to me."
          }
        ]
      }
    },
    {
      "id": "ng-support-functions",
      "type": "NameGenerator",
      "label": "People who support you",
      "interviewScript": "Use these prompts in turn. The same person can be named under more than one prompt. Functions that no one is named for are meaningful: they may indicate a support gap to explore with the participant.",
      "panels": [
        {
          "id": "ng-support-functions-existing",
          "title": "Already mentioned",
          "dataSource": "existing"
        }
      ],
      "subject": { "entity": "node", "type": "supporter" },
      "form": {
        "fields": [
          {
            "variable": "supporter_name",
            "prompt": "What is this person's name or initials?",
            "hint": "Use whatever helps you remember who they are."
          }
        ]
      },
      "prompts": [
        {
          "id": "p-emotional",
          "text": "Who gives you **emotional support** — the people you can talk to, who listen and make you feel cared for?"
        },
        {
          "id": "p-informational",
          "text": "Who do you turn to for **information or advice** about your pregnancy or the baby?"
        },
        {
          "id": "p-practical",
          "text": "Who helps you with **practical tasks or childcare** — things like meals, errands, housework, or looking after the baby?"
        },
        {
          "id": "p-financial",
          "text": "Who provides **financial help** — money, or paying for things you need for yourself or the baby?"
        }
      ]
    },
    {
      "id": "bin-formal-informal",
      "type": "CategoricalBin",
      "label": "Formal or informal sources",
      "subject": { "entity": "node", "type": "supporter" },
      "prompts": [
        {
          "id": "p-formal-informal",
          "text": "For each person, is their support **informal** (family, friends, other parents) or **formal / professional** (a clinician, doula, home-visiting nurse, or community health worker)?",
          "variable": "formal_informal"
        }
      ]
    },
    {
      "id": "alter-support-detail",
      "type": "AlterForm",
      "label": "About each supporter",
      "subject": { "entity": "node", "type": "supporter" },
      "introductionPanel": {
        "title": "A little more about each person",
        "text": "For each person you named, we'll ask a few short questions about where they are, how often you're in contact, and the kinds of support they give you."
      },
      "form": {
        "fields": [
          {
            "variable": "relationship",
            "prompt": "What is this person's relationship to you?"
          },
          {
            "variable": "proximity",
            "prompt": "Where is this person, relative to you, most of the time?"
          },
          {
            "variable": "contact_frequency",
            "prompt": "How often are you in contact with this person at the moment?"
          },
          {
            "variable": "support_functions",
            "prompt": "Which kinds of support does this person give you?",
            "hint": "Select all that apply."
          }
        ]
      }
    },
    {
      "id": "bin-reliance",
      "type": "OrdinalBin",
      "label": "How much you rely on each person",
      "subject": { "entity": "node", "type": "supporter" },
      "prompts": [
        {
          "id": "p-reliance",
          "text": "Thinking about your care and the baby, **how much do you rely on each person** for support overall? Drag each person into the band that fits best.",
          "variable": "reliance"
        }
      ]
    },
    {
      "id": "narrative-support-map",
      "type": "Narrative",
      "label": "Your support map",
      "subject": { "entity": "node", "type": "supporter" },
      "behaviours": {
        "automaticLayout": true,
        "allowRepositioning": true,
        "freeDraw": true
      },
      "presets": [
        {
          "id": "preset-by-source",
          "label": "Support map by source (formal vs informal)",
          "layoutVariable": "layout",
          "groupVariable": "formal_informal",
          "highlight": []
        }
      ],
      "background": {
        "concentricCircles": 3,
        "skewedTowardCenter": true
      },
      "behaviours": {
        "freeDraw": true,
        "allowRepositioning": true
      }
    }
  ]
}
