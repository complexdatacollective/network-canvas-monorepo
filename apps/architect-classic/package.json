    "@babel/plugin-transform-private-property-in-object": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@codaco/interviewer-classic": "workspace:*",
    "@codaco/ui": "^5.8.6",
    "@material-ui/icons": "^4.11.3",
    "@testing-library/jest-dom": "catalog:",
