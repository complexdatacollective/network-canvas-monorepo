{
  "extends": ["../../.oxlintrc.json", "../../tooling/oxlint/react.json"],
  "rules": {
    "react/exhaustive-deps": "warn",
    "no-process-env": "off"
  },
  "overrides": [
    {
      "files": ["development-protocol/**"],
      "rules": { "no-unused-vars": "off" }
    },
    {
      "files": ["src/utils/webShims/**"],
      "rules": { "no-unused-expressions": "off" }
    }
  ],
  "ignorePatterns": [
    "src/utils/protocols/bundleProtocol.js",
    "src/utils/protocols/createProtocol.js",
    "src/utils/protocols/loadProtocolConfiguration.js",
    "src/utils/protocols/saveProtocol.js",
    "src/utils/protocols/unbundleProtocol.js"
  ]
}
