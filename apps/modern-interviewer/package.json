{
	"name": "@codaco/modern-interviewer",
	"private": true,
	"version": "0.1.0",
	"description": "Modern Network Canvas Interviewer — dashboard, runner, and exporter. Builds for web, desktop (Electron) and tablet (Capacitor).",
	"type": "module",
	"main": "dist/electron/main.js",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --build --noEmit && tsc -p tsconfig.node.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"electron:dev": "electron-vite dev",
		"electron:build": "electron-vite build",
		"electron:dist": "pnpm run electron:build && electron-builder --config electron-builder.config.cjs",
		"electron:dist:mac": "pnpm run electron:build && electron-builder --mac --config electron-builder.config.cjs",
		"electron:dist:win": "pnpm run electron:build && electron-builder --win --config electron-builder.config.cjs",
		"electron:dist:linux": "pnpm run electron:build && electron-builder --linux --config electron-builder.config.cjs",
		"capacitor:sync": "pnpm run build && cap sync",
		"capacitor:open:ios": "cap open ios",
		"capacitor:open:android": "cap open android"
	},
	"dependencies": {
		"@base-ui/react": "catalog:",
		"@capacitor/android": "^7.0.0",
		"@capacitor/core": "^7.0.0",
		"@capacitor/filesystem": "^7.0.0",
		"@capacitor/ios": "^7.0.0",
		"@codaco/fresco-ui": "workspace:*",
		"@codaco/interview": "workspace:*",
		"@codaco/network-exporters": "workspace:*",
		"@codaco/network-query": "workspace:*",
		"@codaco/protocol-validation": "workspace:*",
		"@codaco/shared-consts": "workspace:*",
		"@codaco/tailwind-config": "workspace:*",
		"dexie": "^4.4.2",
		"effect": "^3.21.0",
		"jszip": "^3.10.1",
		"lucide-react": "catalog:",
		"motion": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"uuid": "catalog:",
		"wouter": "^3.9.0",
		"zod": "catalog:",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@capacitor/cli": "^7.0.0",
		"@codaco/tsconfig": "workspace:*",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"electron": "^40.8.5",
		"electron-builder": "^26.8.1",
		"electron-vite": "6.0.0-beta.1",
		"jsdom": "^29.0.2",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
