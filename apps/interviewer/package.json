{
  "name": "network-canvas-interviewer",
  "version": "6.6.0",
  "private": true,
  "description": "A tool for conducting Network Canvas Interviews.",
  "homepage": ".",
  "author": "Complex Data Collective",
  "repository": {
    "type": "git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node ../../scripts/with-turbo.mjs --watch-deps electron-vite dev",
    "build": "node ../../scripts/with-turbo.mjs electron-vite build",
    "preview": "electron-vite preview",
    "build:electron": "electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update-snapshots": "vitest run --update",
    "dist:linux": "npm run build && electron-builder -l",
    "dist:mac": "npm run build && electron-builder -m --x64",
    "dist:win": "npm run build && electron-builder -w",
    "build:web": "vite build --config vite.web.config.js",
    "preflight": "oxlint . && vitest run --coverage",
    "version:sync": "node scripts/sync-platform-versions.mjs",
    "cap:sync": "pnpm version:sync && pnpm build:web && cap sync",
    "cap:assets": "capacitor-assets generate --ios --android --assetPath assets/capacitor --iconBackgroundColor \"#e81453\" --iconBackgroundColorDark \"#16152b\" --splashBackgroundColor \"#16152b\" --splashBackgroundColorDark \"#16152b\" --logoSplashScale 0.4",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:run:ios": "pnpm version:sync && pnpm build:web && cap run ios",
    "cap:run:android": "pnpm version:sync && pnpm build:web && cap run android --target Pixel_Tablet_API_35",
    "cap:dev:ios": "pnpm version:sync && pnpm build:web && CAP_DEV_SERVER_URL=http://localhost:5181 cap sync ios && concurrently --kill-others-on-fail -n vite,cap \"vite --config vite.web.config.js\" \"CAP_DEV_SERVER_URL=http://localhost:5181 cap run ios\"",
    "cap:dev:android": "pnpm version:sync && pnpm build:web && CAP_DEV_SERVER_URL=http://10.0.2.2:5181 cap sync android && concurrently --kill-others-on-fail -n vite,cap \"vite --config vite.web.config.js\" \"CAP_DEV_SERVER_URL=http://10.0.2.2:5181 cap run android --target Pixel_Tablet_API_35\""
  },
  "dependencies": {
    "@capacitor/android": "catalog:",
    "@capacitor/app": "catalog:",
    "@capacitor/browser": "catalog:",
    "@capacitor/core": "catalog:",
    "@capacitor/device": "catalog:",
    "@capacitor/filesystem": "catalog:",
    "@capacitor/ios": "catalog:",
    "@capacitor/share": "catalog:",
    "@capawesome/capacitor-file-picker": "catalog:",
    "@codaco/network-exporters": "workspace:*",
    "@codaco/network-query": "workspace:*",
    "archiver": "^7.0.1",
    "d3-force": "~3.0.0",
    "decompress": "^4.2.1",
    "effect": "catalog:",
    "electron-log": "^5.4.4",
    "fs-extra": "^11.3.4",
    "localforage": "^1.10.0",
    "ohash": "~2.0.11"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-json-strings": "7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "~7.18.6",
    "@babel/plugin-syntax-import-meta": "7.10.4",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@capacitor/assets": "catalog:",
    "@capacitor/cli": "catalog:",
    "@codaco/protocol-validation": "^3.0.0",
    "@codaco/shared-consts": "~0.0.1-alpha.3",
    "@codaco/ui": "~5.8.6",
    "@faker-js/faker": "~6.0.0",
    "@material-ui/icons": "^4.11.3",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^4.1.7",
    "animejs": "^2.2.0",
    "autoprefixer": "~10.5.0",
    "buffer": "^5.7.1",
    "classnames": "^2.5.1",
    "color": "^2.0.1",
    "compare-versions": "^3.6.0",
    "concaveman": "^1.2.1",
    "concurrently": "^9.1.0",
    "connected-react-router": "^6.9.3",
    "csvtojson": "^2.0.14",
    "electron": "catalog:",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^3.2.1",
    "electron-vite": "catalog:",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.8",
    "framer-motion": "^2.9.1",
    "fuse.js": "~7.4.0",
    "fuse.js-legacy": "npm:fuse.js@3.4.6",
    "history": "^4.7.2",
    "jsdom": "^27.4.0",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "postcss": "~8.5.15",
    "postcss-flexbugs-fixes": "~4.2.1",
    "postcss-preset-env": "~9.1.4",
    "prop-types": "^15.8.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-flip-toolkit": "^5.0.5",
    "react-redux": "^7.2.1",
    "react-router-dom": "^5.3.4",
    "react-transition-group": "^2.9.0",
    "react-virtualized": "~9.22.6",
    "react-virtualized-auto-sizer": "~1.0.26",
    "react-window": "~1.8.11",
    "recompose": "^0.26.0",
    "redux": "^4.0.5",
    "redux-form": "^8.3.10",
    "redux-logger": "^2.10.2",
    "redux-mock-store": "^1.5.5",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^2.4.2",
    "reselect": "^3.0.1",
    "sanitize-filename": "^1.6.4",
    "sass": "^1.100.0",
    "uuid": "^14.0.0",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "build": {
    "extends": null,
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.bin",
      "!node_modules/.cache",
      "!node_modules/.pnpm",
      "!node_modules/**/*.md",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/README*",
      "!node_modules/**/*.map",
      "!node_modules/**/app-builder-lib/**",
      "!node_modules/**/dmg-builder/**",
      "!node_modules/**/electron-builder/**",
      "!node_modules/**/electron-publish/**",
      "!node_modules/**/builder-util/**",
      "!node_modules/**/builder-util-runtime/**",
      "!node_modules/**/node-gyp/**",
      "!node_modules/**/cacache/**",
      "!node_modules/**/npm/**",
      "!node_modules/**/gyp/**",
      "!node_modules/**/@electron/rebuild/**",
      "!node_modules/**/eslint*/**",
      "!node_modules/**/typescript/**",
      "!node_modules/**/stylelint*/**",
      "!node_modules/**/vitest/**",
      "!node_modules/**/@vitest/**",
      "!node_modules/**/vite/**",
      "!node_modules/**/@babel/core/**",
      "!node_modules/**/@babel/parser/**",
      "!node_modules/**/lodash/**"
    ],
    "extraResources": [
      "./build-resources/externals/**"
    ],
    "appId": "Network-Canvas-Interviewer-6",
    "afterSign": "./build-resources/scripts/afterSignHook.js",
    "directories": {
      "buildResources": "build-resources",
      "output": "release-builds"
    },
    "nsis": {
      "include": "build-resources/scripts/bonjour.nsh"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "entitlements": "./build-resources/entitlements.mac.inherit.plist"
    },
    "linux": {
      "maintainer": "Joshua Melville <joshmelville@gmail.com>",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "complexdatacollective",
        "repo": "interviewer"
      }
    ]
  },
  "cordova": {
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": {
      "cordova-plugin-file-transfer": {},
      "cordova-plugin-device": {},
      "cordova-plugin-app-version": {},
      "cordova-plugin-zeroconf": {},
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-chooser": {},
      "cordova-plugin-network-information": {},
      "cordova-sqlite-storage": {},
      "cordova-plugin-x-socialsharing-android12": {
        "PHOTO_LIBRARY_ADD_USAGE_DESCRIPTION": "This app requires photo library access to function properly.",
        "PHOTO_LIBRARY_USAGE_DESCRIPTION": "This app requires photo library access to function properly."
      },
      "cordova-plugin-androidx-adapter": {},
      "cordova-plugin-network-canvas-client": {},
      "cordova-plugin-fullscreen": {},
      "cordova-plugin-ionic-keyboard": {},
      "cordova-plugin-file": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      }
    }
  },
  "productName": "Network Canvas Interviewer"
}
