{
  "name": "@codaco/interviewer",
  "version": "8.0.0-beta.7",
  "private": true,
  "description": "A tool for conducting Network Canvas Interviews.",
  "author": "Complex Data Collective <hello@complexdatacollective.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
    "directory": "apps/interviewer"
  },
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/with-turbo.mjs --with-deps vite",
    "build": "node ../../scripts/with-turbo.mjs node scripts/build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "storybook": "node ../../scripts/with-turbo.mjs --watch-deps storybook dev -p 6006",
    "build-storybook": "node ../../scripts/with-turbo.mjs storybook build --stats-json",
    "chromatic": "chromatic --only-changed --exit-once-uploaded --auto-accept-changes main --storybook-build-dir=storybook-static --storybook-base-dir=apps/interviewer",
    "test:e2e": "./e2e/scripts/run.sh",
    "test:e2e:update-snapshots": "./e2e/scripts/run.sh --grep @visual --update-snapshots",
    "test:e2e:headed": "pnpm turbo run build --filter=@codaco/interviewer && playwright test --config e2e/playwright.config.ts --headed"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@codaco/art": "workspace:*",
    "@codaco/fresco-ui": "workspace:*",
    "@codaco/interview": "workspace:*",
    "@codaco/network-exporters": "workspace:*",
    "@codaco/protocol-utilities": "workspace:*",
    "@codaco/protocol-validation": "workspace:*",
    "@codaco/protocols": "workspace:*",
    "@codaco/shared-consts": "workspace:*",
    "@codaco/tailwind-config": "workspace:*",
    "@codaco/tsconfig": "workspace:*",
    "@tanstack/react-table": "catalog:",
    "dexie": "^4.4.4",
    "effect": "catalog:",
    "jszip": "catalog:",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-dropzone": "catalog:",
    "uuid": "catalog:",
    "workbox-window": "^7.4.1",
    "wouter": "^3.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "catalog:",
    "@playwright/test": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "chromatic": "catalog:",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "catalog:"
  }
}
