{
  "name": "@codaco/interviewer-v8",
  "version": "8.0.0-alpha.0",
  "private": true,
  "description": "A tool for conducting Network Canvas Interviews.",
  "author": "Complex Data Collective <hello@complexdatacollective.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
    "directory": "apps/interviewer-v8"
  },
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "node ../../scripts/with-turbo.mjs --with-deps vite",
    "build": "node ../../scripts/with-turbo.mjs vite build",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "version:sync": "node scripts/sync-platform-versions.mjs",
    "electron:dev": "node ../../scripts/with-turbo.mjs --watch-deps electron-vite dev",
    "electron:build": "node ../../scripts/with-turbo.mjs electron-vite build",
    "electron:rebuild-deps": "electron-builder install-app-deps",
    "electron:dist": "pnpm electron:build && electron-builder --config electron-builder.config.cjs",
    "electron:dist:mac": "pnpm electron:build && electron-builder --mac --config electron-builder.config.cjs",
    "electron:dist:mac:local": "pnpm electron:build && DEBUG='electron-builder*' electron-builder --mac --arm64 --dir --config electron-builder.config.cjs 2>&1 | tee release-builds/electron-builder-debug.log",
    "electron:dist:win": "pnpm electron:build && electron-builder --win --config electron-builder.config.cjs",
    "electron:dist:linux": "pnpm electron:build && electron-builder --linux --config electron-builder.config.cjs",
    "capacitor:sync": "pnpm version:sync && pnpm build && cap sync",
    "capacitor:add:ios": "cap add ios",
    "capacitor:add:android": "cap add android",
    "capacitor:open:ios": "cap open ios",
    "capacitor:open:android": "cap open android",
    "capacitor:run:ios": "pnpm version:sync && pnpm build && cap run ios",
    "capacitor:run:android": "pnpm version:sync && pnpm build && cap run android",
    "capacitor:dev:android": "pnpm version:sync && pnpm build && node scripts/cap-dev.mjs android ${CAP_ANDROID_TARGET:+--target $CAP_ANDROID_TARGET}",
    "capacitor:dev:ios": "pnpm version:sync && pnpm build && node scripts/cap-dev.mjs ios",
    "assets:generate-inputs": "node scripts/generate-icon-assets.mjs",
    "assets:generate-android": "pnpm assets:generate-inputs && capacitor-assets generate --android --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3",
    "assets:generate-ios": "pnpm assets:generate-inputs && capacitor-assets generate --ios --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3 && node scripts/add-ios-app-icon.mjs",
    "assets:generate-all": "pnpm assets:generate-inputs && capacitor-assets generate --android --ios --iconBackgroundColor \"#f3f2f0\" --splashBackgroundColor \"#f3f2f0\" --logoSplashScale 0.3 && node scripts/add-ios-app-icon.mjs",
    "capacitor:sync:before": "pnpm assets:generate-all",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "storybook": "node ../../scripts/with-turbo.mjs --watch-deps storybook dev -p 6006",
    "build-storybook": "node ../../scripts/with-turbo.mjs storybook build",
    "chromatic": "chromatic --exit-once-uploaded"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@base-ui/react": "catalog:",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@codaco/art": "workspace:*",
    "@codaco/biometric-keystore": "workspace:*",
    "@codaco/fresco-ui": "workspace:*",
    "@codaco/interview": "workspace:*",
    "@codaco/network-exporters": "workspace:*",
    "@codaco/protocol-utilities": "workspace:*",
    "@codaco/protocol-validation": "workspace:*",
    "@codaco/shared-consts": "workspace:*",
    "@codaco/tailwind-config": "workspace:*",
    "@codaco/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-table": "catalog:",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "dexie": "^4.4.3",
    "effect": "catalog:",
    "jszip": "catalog:",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "uuid": "catalog:",
    "wouter": "^3.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@chromatic-com/storybook": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "chromatic": "catalog:",
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "electron-vite": "catalog:",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.2",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "xcode": "^3.0.1"
  }
}
