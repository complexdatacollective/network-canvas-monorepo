# Security headers applied to every response. Unlike Architect and Interviewer
# this app is not a PWA — there is no service worker, manifest, or icon set to
# revalidate — so only the security block, the HTML entry, and the hashed
# assets need cache rules.
/*
  Content-Security-Policy: frame-ancestors 'self'
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/index.html
  Cache-Control: public, max-age=0, must-revalidate
/assets/*
  Cache-Control: public, max-age=31536000, immutable
