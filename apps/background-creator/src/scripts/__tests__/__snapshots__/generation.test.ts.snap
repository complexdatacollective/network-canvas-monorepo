"#!/usr/bin/env python3
# Generated by Network Canvas Background Creator.
# Background: Zone assignment fixture
#
# Assigns a categorical zone label to each node from its layout-variable
# position and writes the result to a new column.
#
# Coordinates are normalized to the range 0-1 with the origin at the top-left
# corner and y increasing downward - the same values Network Canvas stores for
# a layout variable.
#
# This script reads a Network Canvas CSV attribute-list export. It expects the
# columns "<layout>_x" and "<layout>_y" (lowercase, as written by the CSV
# exporter). GraphML exports name the same values "<layout>_X" / "<layout>_Y"
# (uppercase); rename those columns before running this script on GraphML data.
#
# Usage:
#   python assign_zones.py input.csv output.csv
#   python assign_zones.py input.csv output.csv \\
#       --layout-variable location --output-variable zone
#
# Python 3 standard library only - no third-party dependencies.

import argparse
import csv
import math
import sys

ZONES = [
    {"label": "outer", "shape": "circle", "cx": 0.5, "cy": 0.5, "r": 0.45},
    {"label": "middle", "shape": "circle", "cx": 0.5, "cy": 0.5, "r": 0.3},
    {"label": "inner", "shape": "circle", "cx": 0.5, "cy": 0.5, "r": 0.15},
    {"label": "corner-rect", "shape": "rect", "x": 0, "y": 0, "width": 0.2, "height": 0.2},
    {"label": "top-rect", "shape": "rect", "x": 0.4, "y": 0.02, "width": 0.2, "height": 0.2},
    {"label": "triangle", "shape": "polygon", "points": [[0.7, 0.7], [0.95, 0.7], [0.95, 0.95]]},
    {"label": "tie-a", "shape": "rect", "x": 0.05, "y": 0.6, "width": 0.3, "height": 0.2},
    {"label": "tie-b", "shape": "rect", "x": 0.15, "y": 0.55, "width": 0.2, "height": 0.3},
]


def point_in_polygon(x, y, points):
    if len(points) < 3:
        return False
    inside = False
    j = len(points) - 1
    for i in range(len(points)):
        xi, yi = points[i]
        xj, yj = points[j]
        if ((yi > y) != (yj > y)) and (
            x < (xj - xi) * (y - yi) / (yj - yi) + xi
        ):
            inside = not inside
        j = i
    return inside


def point_in_zone(x, y, zone):
    shape = zone["shape"]
    if shape == "rect":
        return (
            zone["x"] <= x <= zone["x"] + zone["width"]
            and zone["y"] <= y <= zone["y"] + zone["height"]
        )
    if shape == "circle":
        dx = (x - zone["cx"]) / zone["r"]
        dy = (y - zone["cy"]) / zone["r"]
        return dx * dx + dy * dy <= 1
    if shape == "polygon":
        return point_in_polygon(x, y, zone["points"])
    return False


def zone_area(zone):
    shape = zone["shape"]
    if shape == "rect":
        return zone["width"] * zone["height"]
    if shape == "circle":
        return math.pi * zone["r"] * zone["r"]
    if shape == "polygon":
        points = zone["points"]
        total = 0.0
        j = len(points) - 1
        for i in range(len(points)):
            xi, yi = points[i]
            xj, yj = points[j]
            total += xj * yi - xi * yj
            j = i
        return abs(total) / 2
    return 0.0


def assign_zone(x, y):
    best_label = None
    best_area = None
    for zone in ZONES:
        if not point_in_zone(x, y, zone):
            continue
        area = zone_area(zone)
        # Smallest containing zone wins; on an exact area tie the later zone in
        # document order wins, so "<=" lets a later equal-area zone replace an
        # earlier one.
        if best_area is None or area <= best_area:
            best_area = area
            best_label = zone["label"]
    return best_label


def parse_coordinate(value):
    if value is None:
        return None
    text = value.strip()
    if text == "":
        return None
    try:
        return float(text)
    except ValueError:
        return None


def main(argv):
    parser = argparse.ArgumentParser(
        description="Assign a Network Canvas background zone to each node.",
    )
    parser.add_argument("input", help="Input CSV (Network Canvas node export).")
    parser.add_argument("output", help="Output CSV file to write.")
    parser.add_argument(
        "--layout-variable",
        default="location",
        help="Name of the layout variable (default: %(default)s).",
    )
    parser.add_argument(
        "--output-variable",
        default="zone",
        help="Name of the column to add (default: %(default)s).",
    )
    args = parser.parse_args(argv)

    x_column = f"{args.layout_variable}_x"
    y_column = f"{args.layout_variable}_y"

    with open(args.input, newline="", encoding="utf-8") as handle:
        reader = csv.DictReader(handle)
        fieldnames = list(reader.fieldnames or [])
        missing = [name for name in (x_column, y_column) if name not in fieldnames]
        if missing:
            found = ", ".join(fieldnames) if fieldnames else "(none)"
            print(
                f"Error: input is missing required column(s): {', '.join(missing)}.",
                file=sys.stderr,
            )
            print(f"Found columns: {found}.", file=sys.stderr)
            return 1
        if args.output_variable in fieldnames:
            print(
                f'Error: output column "{args.output_variable}" already exists '
                "in the input.",
                file=sys.stderr,
            )
            return 1
        rows = list(reader)

    output_fieldnames = fieldnames + [args.output_variable]
    with open(args.output, "w", newline="", encoding="utf-8") as handle:
        writer = csv.DictWriter(handle, fieldnames=output_fieldnames)
        writer.writeheader()
        for row in rows:
            x = parse_coordinate(row.get(x_column))
            y = parse_coordinate(row.get(y_column))
            label = assign_zone(x, y) if x is not None and y is not None else None
            row[args.output_variable] = "" if label is None else label
            writer.writerow(row)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
"
`;

exports[`golden script snapshots > generates the R script 1`] = `
"#!/usr/bin/env Rscript
# Generated by Network Canvas Background Creator.
# Background: Zone assignment fixture
#
# Assigns a categorical zone label to each node from its layout-variable
# position and writes the result to a new column.
#
# Coordinates are normalized to the range 0-1 with the origin at the top-left
# corner and y increasing downward - the same values Network Canvas stores for
# a layout variable.
#
# This script reads a Network Canvas CSV attribute-list export. It expects the
# columns "<layout>_x" and "<layout>_y" (lowercase, as written by the CSV
# exporter). GraphML exports name the same values "<layout>_X" / "<layout>_Y"
# (uppercase); rename those columns before running this script on GraphML data.
#
# Usage:
#   Rscript assign_zones.R input.csv output.csv
#   Rscript assign_zones.R input.csv output.csv \\
#       --layout-variable=location --output-variable=zone
#
# Base R only - no packages required.

zones <- list(
  list(label = "outer", shape = "circle", cx = 0.5, cy = 0.5, r = 0.45),
  list(label = "middle", shape = "circle", cx = 0.5, cy = 0.5, r = 0.3),
  list(label = "inner", shape = "circle", cx = 0.5, cy = 0.5, r = 0.15),
  list(label = "corner-rect", shape = "rect", x = 0, y = 0, width = 0.2, height = 0.2),
  list(label = "top-rect", shape = "rect", x = 0.4, y = 0.02, width = 0.2, height = 0.2),
  list(label = "triangle", shape = "polygon", points = list(c(0.7, 0.7), c(0.95, 0.7), c(0.95, 0.95))),
  list(label = "tie-a", shape = "rect", x = 0.05, y = 0.6, width = 0.3, height = 0.2),
  list(label = "tie-b", shape = "rect", x = 0.15, y = 0.55, width = 0.2, height = 0.3)
)

point_in_polygon <- function(x, y, points) {
  n <- length(points)
  if (n < 3) {
    return(FALSE)
  }
  inside <- FALSE
  j <- n
  for (i in seq_len(n)) {
    xi <- points[[i]][1]
    yi <- points[[i]][2]
    xj <- points[[j]][1]
    yj <- points[[j]][2]
    if (((yi > y) != (yj > y)) &&
      (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
      inside <- !inside
    }
    j <- i
  }
  inside
}

point_in_zone <- function(x, y, zone) {
  if (zone$shape == "rect") {
    return(x >= zone$x && x <= zone$x + zone$width &&
      y >= zone$y && y <= zone$y + zone$height)
  }
  if (zone$shape == "circle") {
    dx <- (x - zone$cx) / zone$r
    dy <- (y - zone$cy) / zone$r
    return(dx * dx + dy * dy <= 1)
  }
  if (zone$shape == "polygon") {
    return(point_in_polygon(x, y, zone$points))
  }
  FALSE
}

zone_area <- function(zone) {
  if (zone$shape == "rect") {
    return(zone$width * zone$height)
  }
  if (zone$shape == "circle") {
    return(pi * zone$r * zone$r)
  }
  if (zone$shape == "polygon") {
    points <- zone$points
    n <- length(points)
    total <- 0
    j <- n
    for (i in seq_len(n)) {
      xi <- points[[i]][1]
      yi <- points[[i]][2]
      xj <- points[[j]][1]
      yj <- points[[j]][2]
      total <- total + (xj * yi - xi * yj)
      j <- i
    }
    return(abs(total) / 2)
  }
  0
}

# Smallest containing zone wins; on an exact area tie the later zone in document
# order wins, so "<=" lets a later equal-area zone replace an earlier one.
assign_zone <- function(x, y) {
  if (is.na(x) || is.na(y)) {
    return(NA_character_)
  }
  best_label <- NA_character_
  best_area <- NA_real_
  for (zone in zones) {
    if (!point_in_zone(x, y, zone)) {
      next
    }
    area <- zone_area(zone)
    if (is.na(best_area) || area <= best_area) {
      best_area <- area
      best_label <- zone$label
    }
  }
  best_label
}

parse_coordinate <- function(value) {
  if (length(value) == 0 || is.na(value)) {
    return(NA_real_)
  }
  text <- trimws(as.character(value))
  if (text == "") {
    return(NA_real_)
  }
  suppressWarnings(as.numeric(text))
}

args <- commandArgs(trailingOnly = TRUE)
layout_variable <- "location"
output_variable <- "zone"
positional <- character(0)
for (arg in args) {
  if (startsWith(arg, "--layout-variable=")) {
    layout_variable <- substring(arg, nchar("--layout-variable=") + 1)
  } else if (startsWith(arg, "--output-variable=")) {
    output_variable <- substring(arg, nchar("--output-variable=") + 1)
  } else {
    positional <- c(positional, arg)
  }
}

if (length(positional) < 2) {
  cat(
    "Usage: Rscript assign_zones.R input.csv output.csv",
    "[--layout-variable=NAME] [--output-variable=NAME]\\n",
    file = stderr()
  )
  quit(status = 1)
}

input_path <- positional[1]
output_path <- positional[2]
x_column <- paste0(layout_variable, "_x")
y_column <- paste0(layout_variable, "_y")

data <- read.csv(input_path, stringsAsFactors = FALSE, check.names = FALSE)
columns <- names(data)
missing <- setdiff(c(x_column, y_column), columns)
if (length(missing) > 0) {
  found <- if (length(columns) > 0) paste(columns, collapse = ", ") else "(none)"
  cat(
    sprintf(
      "Error: input is missing required column(s): %s.\\n",
      paste(missing, collapse = ", ")
    ),
    file = stderr()
  )
  cat(sprintf("Found columns: %s.\\n", found), file = stderr())
  quit(status = 1)
}
if (output_variable %in% columns) {
  cat(
    sprintf(
      "Error: output column \\"%s\\" already exists in the input.\\n",
      output_variable
    ),
    file = stderr()
  )
  quit(status = 1)
}

xs <- vapply(data[[x_column]], parse_coordinate, numeric(1))
ys <- vapply(data[[y_column]], parse_coordinate, numeric(1))
labels <- vapply(
  seq_len(nrow(data)),
  function(i) assign_zone(xs[i], ys[i]),
  character(1)
)
data[[output_variable]] <- labels
write.csv(data, output_path, row.names = FALSE, na = "")
"
`;
