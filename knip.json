{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"ignoreWorkspaces": ["apps/interviewer", "apps/architect-desktop"],
	"tags": ["-public"],
	"workspaces": {
		"packages/ui": {},
		"apps/documentation": {
			"ignore": ["lib/i18n/request.ts", "next-sitemap.config.js"]
		},
		"packages/interview": {
			"entry": [
				"src/**/*.stories.tsx",
				"e2e/specs/**/*.ts",
				"e2e/host/src/main.tsx",
				"e2e/host/vite.config.ts",
				"e2e/host/scripts/*.ts",
				"e2e/helpers/assetServer.ts",
				"e2e/fixtures/window-test.d.ts",
				"e2e/host/src/global-augmentations.d.ts"
			],
			"project": ["src/**/*.{ts,tsx,js}", ".storybook/**/*.{ts,tsx}", "e2e/**/*.{ts,tsx}"],
			"paths": {
				"~/*": ["./*"]
			}
		},
		"packages/protocol-validation": {},
		"packages/network-exporters": {},
		"tooling/tailwind": {
			"entry": [
				"fresco/colors.css",
				"fresco/plugins/elevation/elevation.ts",
				"fresco/plugins/elevation/jwc.ts",
				"fresco/plugins/elevation/utils.ts",
				"fresco/plugins/inset-surface/inset-surface.ts",
				"fresco/plugins/motion-spring.ts"
			],
			"project": ["fresco/**/*.{ts,css}"]
		},
		"apps/architect-vite": {
			"entry": ["index.html!"],
			"vite": true,
			"project": ["src/**/*.{ts,tsx}"],
			"paths": {
				"~/*": ["./src/*"]
			},
			"ignoreDependencies": ["@types/recompose"],
			"ignore": ["src/**/*.d.ts", "src/test/**"]
		},
		"workers/development-protocol": {},
		"workers/posthog-proxy": {}
	}
}
