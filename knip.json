{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreExportsUsedInFile": { "type": true },
  // The legacy app-build workflow (.github/workflows/legacy-app-build.yml)
  // invokes the electron-builder binary, which is a devDependency of the
  // legacy architect app rather than the root, so knip sees it as unlisted.
  // xcrun is the macOS simulator tool used by the Capacitor dev helper.
  // taskkill is the Windows process-termination tool used by
  // apps/architect-classic/scripts/dev.mjs to tear down dev-server processes.
  "ignoreBinaries": ["electron-builder", "xcrun", "taskkill"],
  "tags": ["-public"],
  "workspaces": {
    "apps/networkcanvas.com": {
      "entry": ["lib/i18n/request.ts", "netlify/edge-functions/locale.ts"]
    },
    "apps/documentation": {
      "ignore": ["lib/i18n/request.ts", "next-sitemap.config.js"]
    },
    "packages/interview": {
      "entry": [
        "src/contract/index.ts",
        "src/**/*.stories.tsx",
        "e2e/specs/**/*.ts",
        "e2e/host/src/main.tsx",
        "e2e/host/vite.config.ts",
        "e2e/scripts/*.ts",
        "e2e/helpers/assetServer.ts",
        "e2e/fixtures/window-test.d.ts",
        "e2e/fixtures/dyad-census-window.d.ts",
        "e2e/host/src/global-augmentations.d.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx,js}",
        ".storybook/**/*.{ts,tsx}",
        "e2e/**/*.{ts,tsx}"
      ],
      "paths": {
        "~/*": ["./*"]
      }
    },
    "packages/protocol-validation": {},
    "packages/network-exporters": {},
    "packages/interface-images": {},
    "packages/site-navigation-element": {
      "entry": ["src/styles/shadow.css"],
      "ignoreDependencies": [
        "@fontsource-variable/inclusive-sans",
        "@fontsource-variable/nunito",
        "@tailwindcss/cli"
      ]
    },
    "tooling/tailwind": {
      "entry": [
        "shared/plugins/elevation/index.ts",
        "shared/plugins/elevation/elevation.ts",
        "shared/plugins/elevation/jwc.ts",
        "shared/plugins/elevation/utils.ts",
        "shared/plugins/inset-surface/index.ts",
        "shared/plugins/inset-surface/inset-surface.ts",
        "shared/plugins/motion-spring.ts"
      ],
      "project": ["shared/**/*.ts"],
      "ignoreDependencies": [
        "@fontsource-variable/inclusive-sans",
        "@fontsource-variable/nunito"
      ]
    },
    "apps/interviewer-classic": {
      "project": ["src/**/*.{js,jsx}"],
      "paths": { "@/*": ["./src/*"] },
      "ignore": [
        "src/shims/react-resize-aware.js" // wired via electron.vite.config resolve.alias, not a normal import
      ],
      "ignoreDependencies": [
        "buffer", // npm Buffer polyfill — `import { Buffer } from 'buffer'` in filesystem.js + saveExport.js; knip treats 'buffer' as a Node built-in
        "is-hotkey" // required by @codaco/ui's bundled RichText field; @codaco/ui does not declare it
      ]
    },
    "apps/architect-classic": {
      "entry": ["electron-builder.config.js"],
      "project": ["src/**/*.{js,jsx}"],
      "ignoreDependencies": [
        "react-resizable", // CSS only — @import in main.scss, invisible to knip
        "tippy.js", // CSS only — @import in main.scss, peer dep of @tippyjs/react
        // The preview window renders this app: createPreviewWindow.js resolves it
        // via require.resolve('@codaco/interviewer-classic/package.json') and
        // electron-builder.config.js bundles its out/ — neither a static import.
        "@codaco/interviewer-classic",
        // Used only by the CJS public/ Electron main process, which is excluded
        // from `project` above: knip's CJS export --fix corrupts module.exports
        // in the main-process modules, so that tree is left out of analysis.
        "archiver",
        "decompress",
        "electron-log",
        "electron-devtools-installer"
      ],
      "paths": {
        "@app/*": ["./src/*"],
        "@components/*": ["./src/components/*"],
        "@selectors/*": ["./src/selectors/*"],
        "@hooks/*": ["./src/hooks/*"],
        "@modules/*": ["./src/ducks/modules/*"],
        "@utils/*": ["./src/utils/*"]
      }
    },
    "apps/interviewer": {
      "entry": [
        "index.html!",
        "vite.renderer.config.ts",
        "e2e/specs/**/*.ts",
        "e2e/scripts/*.{ts,mjs}"
      ],
      "vite": true,
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.{ts,tsx}"],
      "paths": {
        "~/*": ["./src/*"]
      }
    },
    "apps/architect": {
      "entry": [
        "index.html!",
        "preview/index.html!",
        "src/preview-main.tsx!",
        "e2e/specs/**/*.ts",
        "e2e/scripts/*.{ts,mjs}"
      ],
      "vite": true,
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.{ts,tsx}"],
      "paths": {
        "~/*": ["./src/*"]
      },
      "ignoreDependencies": ["@types/recompose"],
      "ignore": ["src/**/*.d.ts"]
    },
    "apps/background-creator": {
      "entry": ["index.html!"],
      "vite": true,
      "project": ["src/**/*.{ts,tsx}"],
      "paths": {
        "~/*": ["./src/*"]
      },
      "ignoreBinaries": ["Rscript"]
    },
    "workers/development-protocol": {},
    "workers/posthog-proxy": {}
  }
}
