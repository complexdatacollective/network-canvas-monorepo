{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreExportsUsedInFile": { "type": true },
  // `pnpm exec playwright install` runs in the quality CI job to generate
  // interface screenshots; playwright is a devDependency of
  // @codaco/interface-images, not the root, so knip sees it as unlisted.
  "ignoreBinaries": ["playwright"],
  "tags": ["-public"],
  "workspaces": {
    "packages/ui": {},
    "apps/documentation": {
      "ignore": ["lib/i18n/request.ts", "next-sitemap.config.js"]
    },
    "packages/interview": {
      "entry": [
        "src/**/*.stories.tsx",
        "e2e/specs/**/*.ts",
        "e2e/host/src/main.tsx",
        "e2e/host/vite.config.ts",
        "e2e/scripts/*.ts",
        "e2e/helpers/assetServer.ts",
        "e2e/fixtures/window-test.d.ts",
        "e2e/host/src/global-augmentations.d.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx,js}",
        ".storybook/**/*.{ts,tsx}",
        "e2e/**/*.{ts,tsx}"
      ],
      "paths": {
        "~/*": ["./*"]
      }
    },
    "packages/protocol-validation": {},
    "packages/network-exporters": {},
    "packages/interface-images": {},
    "tooling/tailwind": {
      "entry": [
        "shared/plugins/elevation/index.ts",
        "shared/plugins/elevation/elevation.ts",
        "shared/plugins/elevation/jwc.ts",
        "shared/plugins/elevation/utils.ts",
        "shared/plugins/inset-surface/index.ts",
        "shared/plugins/inset-surface/inset-surface.ts",
        "shared/plugins/motion-spring.ts"
      ],
      "project": ["fresco/**/*.{ts,css}", "shared/**/*.{ts,css}"],
      "ignoreDependencies": [
        "@fontsource-variable/inclusive-sans",
        "@fontsource-variable/nunito"
      ]
    },
    "apps/interviewer": {
      "entry": [
        "src/main/index.js!",
        "src/preload/index.js!",
        "electron.vite.config.js"
      ],
      "project": ["src/**/*.{js,jsx}"],
      "paths": { "@/*": ["./src/*"] },
      "ignore": [
        "src/shims/react-resize-aware.js" // wired via electron.vite.config resolve.alias, not a normal import
      ],
      "ignoreDependencies": [
        "buffer", // npm Buffer polyfill — `import { Buffer } from 'buffer'` in filesystem.js + saveExport.js; knip treats 'buffer' as a Node built-in
        // knip's Capacitor plugin resolves @capacitor/android from
        // android/capacitor.settings.gradle, but only detects iOS via a CocoaPods
        // Podfile — this iOS project uses Swift Package Manager (CapApp-SPM), so
        // @capacitor/ios (native-only, never JS-imported) must be ignored here.
        "@capacitor/ios"
      ]
    },
    "apps/architect": {
      "entry": [
        "public/electron-starter.js!",
        "public/preload/appPreload.js!",
        "public/preload/summaryPreload.js!",
        "electron.vite.config.js",
        "electron-builder.config.js"
      ],
      "project": ["src/**/*.{js,jsx}"],
      "ignoreDependencies": [
        "react-resizable", // CSS only — @import in main.scss, invisible to knip
        "tippy.js", // CSS only — @import in main.scss, peer dep of @tippyjs/react
        // The preview window renders this app: createPreviewWindow.js resolves it
        // via require.resolve('network-canvas-interviewer/package.json') and
        // electron-builder.config.js bundles its out/ — neither a static import.
        "network-canvas-interviewer",
        // Used only by the CJS public/ Electron main process, which is excluded
        // from `project` above: knip's CJS export --fix corrupts module.exports
        // in the main-process modules, so that tree is left out of analysis.
        "archiver",
        "decompress",
        "electron-log",
        "electron-devtools-installer"
      ],
      "paths": {
        "@app/*": ["./src/*"],
        "@components/*": ["./src/components/*"],
        "@selectors/*": ["./src/selectors/*"],
        "@hooks/*": ["./src/hooks/*"],
        "@modules/*": ["./src/ducks/modules/*"],
        "@utils/*": ["./src/utils/*"]
      }
    },
    "apps/interviewer-v8": {
      "entry": [
        "index.html!",
        "electron.vite.config.ts",
        "vite.renderer.config.ts",
        "electron-builder.config.cjs",
        "electron/main.ts",
        "electron/preload.ts"
      ],
      "vite": true,
      "project": ["src/**/*.{ts,tsx}", "electron/**/*.ts"],
      "paths": {
        "~/*": ["./src/*"]
      },
      "ignore": ["src/**/*.d.ts"]
    },
    "apps/architect-web": {
      "entry": ["index.html!", "preview/index.html!", "src/preview-main.tsx!"],
      "vite": true,
      "project": ["src/**/*.{ts,tsx}"],
      "paths": {
        "~/*": ["./src/*"]
      },
      "ignoreDependencies": ["@types/recompose"],
      "ignore": ["src/**/*.d.ts"]
    },
    "workers/development-protocol": {},
    "workers/posthog-proxy": {}
  }
}
