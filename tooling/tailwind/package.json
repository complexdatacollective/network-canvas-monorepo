{
	"name": "@codaco/tailwind-config",
	"version": "0.5.0",
	"description": "Shared Tailwind v4 theme, color palette, and plugins for Fresco and other Codaco apps.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
		"directory": "tooling/tailwind"
	},
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"fresco.css",
		"fresco"
	],
	"exports": {
		"./fresco.css": "./fresco.css",
		"./fresco/themes/default.css": "./fresco/themes/default.css",
		"./fresco/themes/interview.css": "./fresco/themes/interview.css"
	},
	"license": "MIT",
	"scripts": {
		"clean": "rm -rf .turbo node_modules",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"motion": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-animate": "catalog:"
	},
	"devDependencies": {
		"@codaco/tsconfig": "workspace:*",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	}
}
