{
	"name": "@codaco/tailwind-config",
	"version": "0.4.1",
	"description": "Shared Tailwind v4 theme, color palette, and plugins for Fresco and other Codaco apps.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
		"directory": "tooling/tailwind"
	},
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"base.ts",
		"fresco.ts",
		"globals.css",
		"fresco"
	],
	"exports": {
		"./fresco": "./fresco.ts",
		"./fresco/theme.css": "./fresco/theme.css",
		"./fresco/colors.css": "./fresco/colors.css",
		"./fresco/default-theme.css": "./fresco/default-theme.css",
		"./fresco/interview-theme.css": "./fresco/interview-theme.css",
		"./fresco/utilities.css": "./fresco/utilities.css",
		"./fresco/fonts.css": "./fresco/fonts.css",
		"./fresco/plugins/elevation/elevation": "./fresco/plugins/elevation/elevation.ts",
		"./fresco/plugins/inset-surface/inset-surface": "./fresco/plugins/inset-surface/inset-surface.ts",
		"./fresco/plugins/motion-spring": "./fresco/plugins/motion-spring.ts",
		"./base": "./base.ts",
		"./globals.css": "./globals.css"
	},
	"license": "MIT",
	"scripts": {
		"clean": "rm -rf .turbo node_modules",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"motion": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-animate": "catalog:"
	},
	"devDependencies": {
		"@codaco/tsconfig": "workspace:*",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	}
}
