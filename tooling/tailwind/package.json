{
	"name": "@codaco/tailwind-config",
	"version": "1.0.0-alpha.8",
	"description": "Shared Tailwind v4 theme, color palette, and plugins for Fresco and other Codaco apps.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
		"directory": "tooling/tailwind"
	},
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"fresco"
	],
	"exports": {
		"./fresco.css": "./fresco/fresco.css"
	},
	"license": "MIT",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf .turbo node_modules fresco/plugins/**/*.js",
		"prepublishOnly": "pnpm build",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"motion": "catalog:",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@codaco/tsconfig": "workspace:*",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	}
}
