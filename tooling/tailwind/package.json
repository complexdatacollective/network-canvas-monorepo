{
	"name": "@codaco/tailwind-config",
	"version": "1.0.0-alpha.15",
	"description": "Shared Tailwind v4 theme, color palette, and plugins for Fresco and other Codaco apps.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git",
		"directory": "tooling/tailwind"
	},
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"fresco/**",
		"shared/**",
		"tsconfig*.json"
	],
	"exports": {
		"./fresco.css": "./fresco/fresco.css",
		"./colors.css": "./shared/colors.css",
		"./fonts/inclusive-sans.css": "./shared/fonts/inclusive-sans.css",
		"./fonts/nunito.css": "./shared/fonts/nunito.css"
	},
	"license": "MIT",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsgo --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@fontsource-variable/inclusive-sans": "^5.2.8",
		"@fontsource-variable/nunito": "^5.2.7",
		"@tailwindcss/forms": "^0.5.11",
		"motion": "catalog:"
	},
	"peerDependencies": {
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@codaco/tsconfig": "workspace:*",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	}
}
