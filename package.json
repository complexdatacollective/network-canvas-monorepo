{
  "name": "network-canvas-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo watch dev",
    "test": "turbo run test",
    "test:watch": "turbo watch test:watch",
    "test:scripts": "node --test scripts/*.test.mjs",
    "publish-packages": "pnpm exec changeset publish",
    "version-packages": "pnpm exec changeset version && pnpm install --no-frozen-lockfile && pnpm lint:fix",
    "changeset": "changeset add",
    "check:changesets": "node scripts/check-changeset-app-isolation.mjs",
    "verify:publish-exports": "node scripts/verify-publish-exports.mjs",
    "lint": "oxlint && oxfmt --check .",
    "lint:fix": "oxlint --fix --quiet && oxfmt .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck --continue",
    "generate:interface-images": "pnpm --filter @codaco/interface-images generate",
    "prepare": "husky",
    "knip": "knip --exclude catalog"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "catalog:",
    "@typescript/native": "npm:typescript@^7.0.2",
    "husky": "^9.1.7",
    "knip": "^6.26.0",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tailwindcss": "^1.3.5",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "^2.10.4",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "oxlint --fix --quiet",
      "oxfmt"
    ],
    "*.{json,jsonc,md,css,html,yaml,yml}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
