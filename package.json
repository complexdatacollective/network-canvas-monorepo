{
	"private": true,
	"scripts": {
		"build": "turbo run build --filter=!network-canvas-interviewer --filter=!network-canvas-architect",
		"dev": "turbo watch dev",
		"test": "turbo run test --filter=!network-canvas-interviewer --filter=!network-canvas-architect",
		"test:watch": "turbo watch test:watch --filter=!network-canvas-interviewer --filter=!network-canvas-architect",
		"publish-packages": "pnpm exec changeset publish",
		"version-packages": "pnpm exec changeset version && pnpm install --no-frozen-lockfile && pnpm lint:fix",
		"changeset": "changeset add",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"typecheck": "turbo run typecheck --continue --filter=!network-canvas-interviewer --filter=!network-canvas-architect",
		"prepare": "husky",
		"knip": "knip --exclude catalog"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@changesets/cli": "^2.31.0",
		"@types/node": "catalog:",
		"@typescript/native-preview": "^7.0.0-dev.20260421.2",
		"husky": "^9.1.7",
		"knip": "^6.6.2",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.6",
		"typescript": "catalog:"
	},
	"pnpm": {
		"overrides": {
			"react-resize-aware": "3.1.3",
			"cheerio": "1.0.0-rc.12",
			"immer": "catalog:"
		}
	},
	"packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
	"name": "network-canvas-monorepo",
	"lint-staged": {
		"*": "pnpm run lint:fix"
	}
}
