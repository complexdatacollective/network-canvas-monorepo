{
	"extends": "@codaco/tsconfig/web.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
		"outDir": "dist"
	},
	"include": ["src", ".storybook", "vite.config.ts"],
	"exclude": ["node_modules", "dist", "src/**/*.stories.tsx", "src/**/*.test.*", "src/**/*.spec.*", "**/__tests__/**"]
}
