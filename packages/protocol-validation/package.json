{
  "name": "@codaco/protocol-validation",
  "version": "11.11.0",
  "description": "Utilities for validating and migrating Network Canvas protocol files.",
  "license": "GPL-3.0-or-later",
  "author": "Complex Data Collective <hello@complexdatacollective.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/complexdatacollective/network-canvas-monorepo.git"
  },
  "bin": {
    "@codaco/protocol-validation": "./scripts/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --noEmit"
  },
  "dependencies": {
    "@codaco/shared-consts": "workspace:^",
    "ohash": "^2.0.11",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codaco/tsconfig": "workspace:^",
    "@octokit/types": "^16.0.0",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/tar-stream": "^3.1.4",
    "dotenv": "catalog:",
    "gunzip-maybe": "^1.4.2",
    "jszip": "catalog:",
    "tar-stream": "^3.2.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
