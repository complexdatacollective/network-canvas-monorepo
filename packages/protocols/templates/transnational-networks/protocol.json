{
  "name": "Transnational Networks",
  "description": "An example template for studying the personal networks of people who have migrated. It pairs separate name generators for important people in the host country and abroad with a geospatial stage that places those people on a world map.",
  "schemaVersion": 8,
  "lastModified": "2026-07-09T13:28:12.372Z",
  "assetManifest": {
    "mapbox-testing-token": {
      "id": "mapbox-testing-token",
      "type": "apikey",
      "name": "Mapbox token (testing only)",
      "value": "pk.eyJ1IjoibmV0d29ya2NhbnZhcyIsImEiOiJjbTZmaDJ0cTcwNTVpMmtvbDZhcXJneG1hIn0.wI5ooUHDWwFsH4jLXo3CVw"
    },
    "world-countries-geojson": {
      "id": "world-countries-geojson",
      "type": "geojson",
      "name": "World countries (boundaries)",
