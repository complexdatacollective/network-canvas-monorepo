{
	"name": "@codaco/fresco-ui",
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"description": "Fresco UI components, styles, and utilities",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"exports": {
		"./_placeholder": {
			"types": "./dist/_placeholder.d.ts",
			"default": "./dist/_placeholder.js"
		}
	},
	"scripts": {
		"build": "node scripts/build-exports.mjs && vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --build --noEmit",
		"test": "vitest run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepublishOnly": "pnpm build",
		"clean": "rm -rf .turbo node_modules dist"
	},
	"peerDependencies": {
		"@codaco/protocol-validation": "catalog:",
		"@codaco/shared-consts": "catalog:",
		"immer": "catalog:",
		"motion": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwindcss": "catalog:",
		"zod": "catalog:",
		"zustand": "catalog:"
	},
	"dependencies": {
		"@base-ui/react": "catalog:",
		"@radix-ui/react-slot": "catalog:",
		"@tiptap/core": "catalog:",
		"@tiptap/extension-bullet-list": "catalog:",
		"@tiptap/extension-heading": "catalog:",
		"@tiptap/extension-ordered-list": "catalog:",
		"@tiptap/extension-paragraph": "catalog:",
		"@tiptap/pm": "catalog:",
		"@tiptap/react": "catalog:",
		"@tiptap/starter-kit": "catalog:",
		"comlink": "catalog:",
		"cva": "catalog:",
		"es-toolkit": "catalog:",
		"fuse.js": "catalog:",
		"lucide-react": "catalog:",
		"nanoid": "catalog:",
		"react-aria-components": "catalog:",
		"react-best-merge-refs": "catalog:",
		"react-markdown": "catalog:",
		"rehype-raw": "catalog:",
		"rehype-sanitize": "catalog:",
		"remark-gemoji": "catalog:",
		"tailwind-merge": "catalog:"
	},
	"devDependencies": {
		"@codaco/tsconfig": "workspace:*",
		"@biomejs/biome": "^2.4.13",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "^5.0.0",
		"tinyglobby": "^0.2.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
