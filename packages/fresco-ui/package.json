    "test": "vitest run --project=unit",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "storybook": "node ../../scripts/with-turbo.mjs --watch-deps storybook dev -p 6006",
    "build-storybook": "node ../../scripts/with-turbo.mjs storybook build --stats-json",
    "chromatic": "chromatic --only-changed --exit-once-uploaded --auto-accept-changes main --storybook-build-dir=storybook-static --storybook-base-dir=packages/fresco-ui",
