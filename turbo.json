{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "NC_PREVIEW_HOST",
    "NEXT_PUBLIC_ALGOLIA_APPLICATION_ID",
    "NEXT_PUBLIC_ALGOLIA_INDEX_NAME",
    "NEXT_PUBLIC_ALGOLIA_API_KEY",
    "NEXT_PUBLIC_MENDABLE_ANON_KEY",
    "NEXT_PUBLIC_GA_ID",
    "VITE_FRESCO_PREVIEW_URL",
    "VITE_FRESCO_PREVIEW_API_TOKEN",
    "VITE_DISABLE_ANALYTICS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "vite.config.*",
        "electron.vite.config.*",
        "next.config.*",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", "out/**", ".next/**", "!.next/cache/**"]
    },
    "@codaco/documentation#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/documentation/**",
        "app/**",
        "components/**",
        "hooks/**",
        "lib/**",
        "messages/**",
        "docs/**",
        "public/**",
        "scripts/**",
        "styles/**",
        "tailwind/**",
        "env.js",
        "navigation.ts",
        "instrumentation-client.ts",
        "types.d.ts",
        "next.config.*",
        "next-sitemap.config.*",
        "postcss.config.*",
        "tailwind.config.*",
        "tsconfig*.json",
        "components.json",
        "package.json"
      ],
      "env": [
        "NEXT_PUBLIC_ALGOLIA_APPLICATION_ID",
        "NEXT_PUBLIC_ALGOLIA_INDEX_NAME",
        "NEXT_PUBLIC_ALGOLIA_API_KEY",
        "NEXT_PUBLIC_MENDABLE_ANON_KEY",
        "NEXT_PUBLIC_GA_ID"
      ],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"]
    },
    "@codaco/architect#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/**",
        "src/**",
        "scripts/**",
        "public/**",
        "index.html",
        "preview/index.html",
        "vite.config.*",
        "tailwind.config.*",
        "tsconfig*.json",
        "vite-env.d.ts",
        "package.json"
      ],
      "env": [
        "VITE_FRESCO_PREVIEW_URL",
        "VITE_FRESCO_PREVIEW_API_TOKEN",
        "VITE_DISABLE_ANALYTICS"
      ],
      "outputs": ["dist/**"]
    },
    "@codaco/interviewer#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/development/**",
        "$TURBO_ROOT$/packages/protocols/sample/**",
        "src/**",
        "scripts/**",
        "public/**",
        "index.html",
        "vite.config.*",
        "tailwind.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**"]
    },
    "networkcanvas.com#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "content/**",
        "font-modules.d.ts",
        "lib/**",
        "messages/**",
        "netlify/**",
        "netlify.toml",
        "public/**",
        "types.d.ts",
        "next.config.*",
        "postcss.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"]
    },
    "networkcanvas.com#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "content/**",
        "font-modules.d.ts",
        "lib/**",
        "messages/**",
        "netlify/**",
        "types.d.ts",
        "next.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "networkcanvas.com#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "content/**",
        "lib/**",
        "messages/**",
        "netlify/**",
        "test/**",
        "vitest.config.*",
        "vitest.setup.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "@codaco/interviewer-classic#build:web": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "index.html",
        "vite.web.config.*",
        "vite.renderer.shared.*",
        "package.json"
      ],
      "outputs": ["dist-web/**"]
    },
    "@codaco/architect-classic#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "scripts/**",
        "babel.config.*",
        "postcss.config.*",
        "electron.vite.config.*",
        "electron-builder.config.*",
        "package.json"
      ],
      "outputs": ["out/**", "dist/**"]
    },
    "@codaco/site-navigation-element#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig*.json",
        "vite.config.*",
        "package.json",
        "$TURBO_ROOT$/tooling/tailwind/**"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", ".generated/**"]
    },
    "@codaco/site-navigation-element#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "vitest.config.*",
        "vite.config.*",
        "tsconfig*.json",
        "package.json",
        "$TURBO_ROOT$/tooling/tailwind/**"
      ],
      "outputs": []
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/tooling/tailwind/**",
        "src/**",
        ".storybook/**",
        "stories/**",
        "package.json",
        "tsconfig*.json"
      ],
      "env": ["NODE_ENV", "STORYBOOK_MAPBOX_TOKEN"],
      "outputs": ["storybook-static/**"]
    },
    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "//#lint": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs,json}",
        "**/biome.json",
        ".gitignore",
        "!**/dist/**",
        "!**/out/**",
        "!**/.next/**",
        "!**/storybook-static/**",
        "!**/node_modules/**"
      ],
      "outputs": []
    },
    "//#knip": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs}",
        "**/package.json",
        "**/tsconfig*.json",
        "knip.json",
        "pnpm-workspace.yaml",
        "pnpm-lock.yaml",
        "!**/dist/**",
        "!**/out/**",
        "!**/.next/**",
        "!**/node_modules/**"
      ],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "@codaco/architect#dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "@codaco/documentation#dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "__tests__/**",
        "vitest.config.*",
        "package.json",
        ".env"
      ],
      "env": [
        "PROTOCOL_ENCRYPTION_KEY",
        "PROTOCOL_ENCRYPTION_IV",
        "GITHUB_TOKEN"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e:headed": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@codaco/documentation#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "hooks/**",
        "lib/**",
        "scripts/**",
        "env.js",
        "navigation.ts",
        "instrumentation-client.ts",
        "types.d.ts",
        "next.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "@codaco/architect#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/**",
        "src/**",
        "scripts/**",
        "vite.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": []
    },
    "@codaco/interviewer#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/development/**",
        "$TURBO_ROOT$/packages/protocols/sample/**",
        "src/**",
        "scripts/**",
        "vite.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": []
    },
    "@codaco/architect#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/**",
        "src/**",
        "scripts/**",
        "__tests__/**",
        "vitest.config.*",
        "vite.config.*",
        "package.json",
        ".env"
      ],
      "env": [
        "PROTOCOL_ENCRYPTION_KEY",
        "PROTOCOL_ENCRYPTION_IV",
        "GITHUB_TOKEN"
      ],
      "outputs": []
    },
    "@codaco/protocol-validation#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/e2e/all-interfaces/**",
        "src/**",
        "__tests__/**",
        "vitest.config.*",
        "package.json",
        ".env"
      ],
      "env": [
        "PROTOCOL_ENCRYPTION_KEY",
        "PROTOCOL_ENCRYPTION_IV",
        "GITHUB_TOKEN"
      ],
      "outputs": []
    },
    "@codaco/interviewer#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_ROOT$/packages/protocols/development/**",
        "$TURBO_ROOT$/packages/protocols/sample/**",
        "src/**",
        "__tests__/**",
        "vitest.config.*",
        "vite.config.*",
        "package.json",
        ".env"
      ],
      "env": [
        "PROTOCOL_ENCRYPTION_KEY",
        "PROTOCOL_ENCRYPTION_IV",
        "GITHUB_TOKEN"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"],
      "env": ["NODE_ENV"],
      "outputs": []
    }
  }
}
