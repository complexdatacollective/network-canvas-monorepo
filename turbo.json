{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["pnpm-lock.yaml", "pnpm-workspace.yaml"],
  "globalPassThroughEnv": [
    "NC_PREVIEW_HOST",
    "NEXT_PUBLIC_ALGOLIA_APPLICATION_ID",
    "NEXT_PUBLIC_ALGOLIA_INDEX_NAME",
    "NEXT_PUBLIC_ALGOLIA_API_KEY",
    "NEXT_PUBLIC_MENDABLE_ANON_KEY",
    "NEXT_PUBLIC_GA_ID",
    "VITE_FRESCO_PREVIEW_URL",
    "VITE_FRESCO_PREVIEW_API_TOKEN",
    "VITE_DISABLE_ANALYTICS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "vite.config.*",
        "electron.vite.config.*",
        "next.config.*",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", "out/**", ".next/**", "!.next/cache/**"]
    },
    "@codaco/biometric-keystore#build": {
      "inputs": [
        "src/**",
        "build.rs",
        "Cargo.toml",
        "Cargo.lock",
        "scripts/**",
        "package.json"
      ],
      "outputs": ["biometric-keystore.darwin-*.node"]
    },
    "@codaco/interviewer-v7#electron:build": {
      "dependsOn": ["^build"],
      "inputs": [
        "electron/**",
        "src/**",
        "index.html",
        "electron.vite.config.*",
        "vite.renderer.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["dist-electron/**"]
    },
    "@codaco/interviewer-v7#electron:rebuild-deps": {
      "cache": false
    },
    "@codaco/interviewer-v7#electron:dev": {
      "dependsOn": ["^build", "electron:rebuild-deps"],
      "cache": false,
      "persistent": true
    },
    "@codaco/documentation#build": {
      "dependsOn": ["^build", "@codaco/interface-images#generate"],
      "inputs": [
        "app/**",
        "components/**",
        "hooks/**",
        "lib/**",
        "messages/**",
        "docs/**",
        "public/**",
        "scripts/**",
        "styles/**",
        "tailwind/**",
        "env.js",
        "navigation.ts",
        "instrumentation-client.ts",
        "types.d.ts",
        "next.config.*",
        "next-sitemap.config.*",
        "postcss.config.*",
        "tailwind.config.*",
        "tsconfig*.json",
        "components.json",
        "package.json"
      ],
      "env": [
        "NEXT_PUBLIC_ALGOLIA_APPLICATION_ID",
        "NEXT_PUBLIC_ALGOLIA_INDEX_NAME",
        "NEXT_PUBLIC_ALGOLIA_API_KEY",
        "NEXT_PUBLIC_MENDABLE_ANON_KEY",
        "NEXT_PUBLIC_GA_ID"
      ],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"]
    },
    "@codaco/architect-web#build": {
      "dependsOn": ["^build", "@codaco/interface-images#generate"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "vite.config.*",
        "tailwind.config.*",
        "tsconfig*.json",
        "vite-env.d.ts",
        "package.json"
      ],
      "env": [
        "VITE_FRESCO_PREVIEW_URL",
        "VITE_FRESCO_PREVIEW_API_TOKEN",
        "VITE_DISABLE_ANALYTICS"
      ],
      "outputs": ["dist/**"]
    },
    "networkcanvas.com#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "public/**",
        "types.d.ts",
        "next.config.*",
        "postcss.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": ["NODE_ENV"],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"]
    },
    "networkcanvas.com#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "types.d.ts",
        "next.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "network-canvas-interviewer#build:web": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "index.html",
        "vite.web.config.*",
        "vite.renderer.shared.*",
        "package.json"
      ],
      "outputs": ["dist-web/**"]
    },
    "network-canvas-architect#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "scripts/**",
        "babel.config.*",
        "postcss.config.*",
        "electron.vite.config.*",
        "electron-builder.config.*",
        "package.json"
      ],
      "outputs": ["out/**", "dist/**"]
    },
    "@codaco/interface-images#generate": {
      "inputs": ["scripts/**", "package.json"],
      "env": ["STORYBOOK_MAPBOX_TOKEN", "INTERVIEW_RELEASE_VERSION"],
      "passThroughEnv": ["PLAYWRIGHT_BROWSERS_PATH"],
      "outputs": ["src/generated/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        ".storybook/**",
        "stories/**",
        "package.json",
        "tsconfig*.json"
      ],
      "env": ["NODE_ENV", "STORYBOOK_MAPBOX_TOKEN"],
      "outputs": ["storybook-static/**"]
    },
    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "//#lint": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs,json}",
        "**/biome.json",
        ".gitignore",
        "!**/dist/**",
        "!**/out/**",
        "!**/.next/**",
        "!**/storybook-static/**",
        "!**/node_modules/**"
      ],
      "outputs": []
    },
    "//#knip": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs}",
        "**/package.json",
        "**/tsconfig*.json",
        "knip.json",
        "pnpm-workspace.yaml",
        "pnpm-lock.yaml",
        "!**/dist/**",
        "!**/out/**",
        "!**/.next/**",
        "!**/node_modules/**"
      ],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "__tests__/**",
        "vitest.config.*",
        "package.json",
        ".env"
      ],
      "env": [
        "PROTOCOL_ENCRYPTION_KEY",
        "PROTOCOL_ENCRYPTION_IV",
        "GITHUB_TOKEN"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e:headed": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@codaco/documentation#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "hooks/**",
        "lib/**",
        "scripts/**",
        "env.js",
        "navigation.ts",
        "instrumentation-client.ts",
        "types.d.ts",
        "next.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"],
      "env": ["NODE_ENV"],
      "outputs": []
    }
  }
}
